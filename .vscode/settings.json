{
    "editor.tabSize": 5,
    "editor.insertSpaces": true,
    "editor.rulers": [100],
    "files.associations": {
        "*.slua": "slua"
    },
    "clangd.enableCodeCompletion": true,
    "clangd.arguments": [
        "--compile-commands-dir=${workspaceFolder}/build",
        "--background-index",
        "--clang-tidy=false"
    ],
    "C_Cpp.files.exclude": {
        "**/*.slua": true
    },
    "C_Cpp.intelliSenseEngine": "default",
    "C_Cpp.errorSquiggles": "enabled",
    "Lua.diagnostics.enable": false,
    "Lua.workspace.ignoreDir": [],
    "cSpell.ignorePaths": ["**/*.slua"],
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.patterns": {
        "*.slua": "${capture}.slua.sig"
    },
    "terminal.integrated.defaultProfile.windows": "PowerShell",
    "cmake.buildDirectory": "${workspaceFolder}/build",
    "cmake.configureOnOpen": false,
    "cmake.buildBeforeRun": false,
    "cmake.statusBarVisibility": "hidden",
    "chat.tools.terminal.autoApprove": {
        "/^cd \"c:\\\\Users\\\\rajeev\\\\slua-compiler\" ; powershell -ExecutionPolicy Bypass -Command @\"\n`\\$examples = @\\(\"loop\\.slua\", \"math_test\\.slua\", \"stdlib_test\\.slua\", \"enum\\.slua\", \"test_nonstrict\\.slua\", \"String\\.slua\"\\)\nforeach \\(`\\$ex in `\\$examples\\) \\{\n    Write-Host \"Testing `\\$ex\\.\\.\\.\" -ForegroundColor Cyan\n    & \"\\.\\\\slua\\.ps1\" -Command \"Slua-Run\" -File \"examples/`\\$ex\" 2>&1 \\| Select-Object -First 5\n    Write-Host \"\"\n\\}\n\"@\n$/": {
            "approve": true,
            "matchCommandLine": true
        }
    }
}