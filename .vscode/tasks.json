{
    "version": "2.0.0",
    "tasks": [

        {
            "label": "slua: run current file",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}\\slua.ps1",
                "Slua-Run",
                "${relativeFile}"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true,
                "focus": true,
                "showReuseMessage": false
            },
            "problemMatcher": {
                "owner": "sluac",
                "fileLocation": ["relative", "${workspaceFolder}"],
                "pattern": {
                    "regexp": "^\\[([EW][\\w]+)\\]\\s+(\\S+):(\\d+):(\\d+)\\s+(.*)$",
                    "severity": 1,
                    "file": 2,
                    "line": 3,
                    "column": 4,
                    "message": 5
                }
            }
        },

        {
            "label": "slua: build compiler",
            "type": "shell",
            "command": "${workspaceFolder}\\cmake_configure.bat",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true,
                "showReuseMessage": false
            },
            "problemMatcher": []
        },

        {
            "label": "sluac: emit AST (current file)",
            "type": "shell",
            "command": "${workspaceFolder}\\build\\compiler\\sluac.exe",
            "args": ["${file}", "--emit-ast"],
            "group": "test",
            "presentation": { "reveal": "always", "panel": "shared", "clear": true, "showReuseMessage": false },
            "problemMatcher": []
        },

        {
            "label": "sluac: emit IR (current file)",
            "type": "shell",
            "command": "${workspaceFolder}\\build\\compiler\\sluac.exe",
            "args": ["${file}", "-o", "${fileDirname}\\${fileBasenameNoExtension}.ll"],
            "group": "test",
            "presentation": { "reveal": "always", "panel": "shared", "clear": true, "showReuseMessage": false },
            "problemMatcher": []
        }
    ]
}