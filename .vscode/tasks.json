{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "sluac: build",
            "type": "shell",
            "command": "${workspaceFolder}\\cmake_configure.bat",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "sluac: emit tokens (current file)",
            "type": "shell",
            "command": "${workspaceFolder}\\build\\compiler\\sluac.exe",
            "args": [
                "${file}",
                "--emit-tokens"
            ],
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": {
                "owner": "sluac",
                "fileLocation": ["relative", "${workspaceFolder}"],
                "pattern": {
                    "regexp": "^\\[E\\w+\\]\\s+(\\S+):(\\d+):(\\d+)\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "message": 4
                }
            }
        },
        {
            "label": "sluac: emit AST (current file)",
            "type": "shell",
            "command": "${workspaceFolder}\\build\\compiler\\sluac.exe",
            "args": [
                "${file}",
                "--emit-ast"
            ],
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": {
                "owner": "sluac",
                "fileLocation": ["relative", "${workspaceFolder}"],
                "pattern": {
                    "regexp": "^\\[E\\w+\\]\\s+(\\S+):(\\d+):(\\d+)\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "message": 4
                }
            }
        },
        {
            "label": "sluac: check (current file)",
            "type": "shell",
            "command": "${workspaceFolder}\\build\\compiler\\sluac.exe",
            "args": [
                "${file}"
            ],
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": {
                "owner": "sluac",
                "fileLocation": ["relative", "${workspaceFolder}"],
                "pattern": {
                    "regexp": "^\\[EE?(\\w+)\\]\\s+(\\S+):(\\d+):(\\d+)\\s+(.*)$",
                    "file": 2,
                    "line": 3,
                    "column": 4,
                    "message": 5,
                    "severity": 1
                }
            }
        },
        {
            "label": "sluac: emit IR (current file)",
            "type": "shell",
            "command": "${workspaceFolder}\\build\\compiler\\sluac.exe",
            "args": [
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.ll"
            ],
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": {
                "owner": "sluac",
                "fileLocation": ["relative", "${workspaceFolder}"],
                "pattern": {
                    "regexp": "^\\[EE?(\\w+)\\]\\s+(\\S+):(\\d+):(\\d+)\\s+(.*)$",
                    "file": 2,
                    "line": 3,
                    "column": 4,
                    "message": 5
                }
            }
        }
    ]
}