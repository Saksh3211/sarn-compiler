{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug sluac (current file)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/compiler/sluac.exe",
            "args": ["${file}"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/bin",
            "environment": [],
            "console": "integratedTerminal"
        },
        {
            "name": "Run (current file)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/slua.ps1",
                "Slua-Run",
                "${file}"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        }
    ]
}
