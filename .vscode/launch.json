{
    "version": "0.2.0",

    // ─────────────────────────────────────────────────────────────────────────
    // NOTE: F5 on .slua files is handled by the S Lua extension keybinding
    // (defined in the extension's package.json), NOT by these launch configs.
    // These configs are for debugging the sluac compiler itself (C++ code).
    // ─────────────────────────────────────────────────────────────────────────

    "configurations": [

        {
            "name": "Debug sluac (current .slua file)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/compiler/sluac.exe",
            "args": ["${file}"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "integratedTerminal",
            "presentation": {
                "hidden": false,
                "group": "compiler",
                "order": 1
            }
        },

        {
            "name": "Debug sluac (hello_strict.slua)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/compiler/sluac.exe",
            "args": ["examples/hello_strict.slua", "--emit-ast"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "integratedTerminal",
            "presentation": {
                "hidden": false,
                "group": "compiler",
                "order": 2
            }
        },

        {
            "name": "Debug sluac (enum.slua)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/compiler/sluac.exe",
            "args": ["examples/enum.slua"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "integratedTerminal",
            "presentation": {
                "hidden": false,
                "group": "compiler",
                "order": 3
            }
        }
    ]
}