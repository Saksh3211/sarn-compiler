{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug sluac (current file)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/compiler/sluac.exe",
            "args": ["${file}"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "integratedTerminal"
        },
        {
            "name": "Debug sluac (hello_strict.slua --emit-ast)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/compiler/sluac.exe",
            "args": ["examples/hello_strict.slua", "--emit-ast"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "integratedTerminal"
        },
        {
            "name": "Debug sluac (enum.slua)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/compiler/sluac.exe",
            "args": ["examples/enum.slua"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "integratedTerminal"
        }
    ]
}