--!!type:strict

function process_int(x: int): int
    if x == 0 then
        return 0
    else
        return x + 100
    end
end

function process_string(s: string): int
    if s == "" then
        return 0
    else
        return 1
    end
end

function main(): int
    local result1: int = process_int(42)
    print(result1)
    
    local result2: int = process_string("hello")
    print(result2)
    
    return 0
end
