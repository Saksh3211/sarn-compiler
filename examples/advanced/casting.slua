--!!type:strict

function cast_demo(): int
    local num: number = 3.14
    local truncated: int = cast(int, num)
    print(truncated)
    
    local small: int = 256
    local byte_val: uint8 = cast(uint8, small)
    print(byte_val)
    
    local back: number = cast(number, 100)
    print(back)
    
    return 0
end

function main(): int
    cast_demo()
    return 0
end
