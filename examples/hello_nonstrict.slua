--!!type:nonstrict

function main()
    local x             
    local y = x + 5     
    print(y)         

    local name = "World"
    print("Hello, " .. name)

    local scores = { 95, 87, 72, 100, 63 }
    local total = 0
    for i = 1, #scores do
        total = total + scores[i]
    end
    print(total)

    local raw = read_line()
    if not raw then
        print("You typed: " .. raw)
    end
end