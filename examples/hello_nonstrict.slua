--!!type:nonstrict
import io

function main()
    local x = 1            
    local y = x + 5     
    print(y)         

    local name = "World"
    print("Hello, " .. name)

    local scores = { 95, 87, 72, 100, 63 }
    local total = 0
    for i = 1, #scores,i+1 do
        total = total + scores[i]
    end
    print(total)

    local raw = io.read_line()
    if raw then
        print("You typed: " .. raw)
    end
end