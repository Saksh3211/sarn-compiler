--!!type:strict

function main(): int
    for i = 0, 5, 1 do
        print(i)
    end
    
    print("---")
    
    for i = 0, i < 3, i + 1 do
        print(i)
    end
    
    print("---")
    
    local x: int = 0
    repeat
        print(x)
        x = x + 1
    until x >= 3
    
    return 0
end
