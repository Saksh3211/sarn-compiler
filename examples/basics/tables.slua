--!!type:nonstrict

function main()
    local nums = {10, 20, 30, 40, 50}
    
    print(nums[0])
    print(nums[1])
    print(nums[4])
    
    print(#nums)
    
    local person = {}
    person["name"] = "Alice"
    person["age"] = 30
    
    print(person["name"])
    print(person["age"])
    
    return 0
end
