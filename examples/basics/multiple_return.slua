--!!type:strict

function sum_rest(first: int, rest: int): int, int
    return first + rest, first - rest
end

function main(): int
    local a: int = 10
    local b: int = 3
    
    local add_result: int, sub_result: int = sum_rest(a, b)
    
    print(add_result)
    print(sub_result)
    
    return 0
end
