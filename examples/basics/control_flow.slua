--!!type:strict

function main(): int
    local x: int = 5
    
    if x > 0 then
        print("positive")
    elseif x < 0 then
        print("negative")
    else
        print("zero")
    end
    
    local y: int = 0
    while y < 3 do
        print(y)
        y = y + 1
    end
    
    return 0
end
