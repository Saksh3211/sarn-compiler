--!!type:nonstrict

function main()
    local s = "Hello, World"
    
    print(s .. "!")
    
    local a = "foo"
    local b = "bar"
    local combined = a .. b
    print(combined)
    
    local lines = "line1\nline2\nline3"
    print(lines)
    
    local tab = "col1\tcol2\tcol3"
    print(tab)
    
    return 0
end
