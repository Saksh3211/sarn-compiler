--!!type:strict

function main(): int
    for i = 0, 10, 1 do
        if i == 3 then
            break
        end
        print(i)
    end
    
    print("after break")
    
    for i = 0, 5, 1 do
        if i == 2 then
            continue
        end
        print(i)
    end
    
    return 0
end
