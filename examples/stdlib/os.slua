--!!type:strict
import os

function main(): int
    local ts: int = os.time()
    print(ts)
    
    local cwd: string = os.cwd()
    print(cwd)
    
    local home: string = os.getenv("USERPROFILE")
    print(home)
    
    print("Sleeping 1 second...")
    os.sleep(1000)
    print("Done")
    
    os.system("echo Hello from shell command")
    
    return 0
end
