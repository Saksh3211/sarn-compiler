--!!type:strict
--!!mem:auto

function add(a:int64, b:int64):int64
    return a + b
end

function retable():table
    local t:table= {1,2,3}
    return t
end

function main():int64
    local t:table = retable()
    local a:int64 = t[1]
    local b:int64 = t[3]
    local result:int64 = add(a, b)
    print(result)
    return 0
end