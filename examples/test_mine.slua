--!!type:strict
--!!mem:auto
import stdata
import ("utils.slua")

function retable():table
    local t:table= {}
    t[1]=2
    t[2]=5
    return t
end

function main():int
    local t:table = retable()
    local a:int64 = t[1]
    local b:int64 = t[2]
    local result:int64 = add(a, b)
    t["ba"]="abc"
    print(result)
    local str:string = t["ba"]
    print(str)

    print("umm , type library")
    local x:int64 = 10
    print(stdata.typeof(x))        -- "int"
    print(stdata.tostring(x))      -- "42"
    print(stdata.tofloat(x))       -- 42.0
    print(stdata.tobool(x))        -- true
    print(stdata.isnull(x))        -- false
    stdata.assert(x > 0, "x must be positive")
    return 0
end