--!!type:strict
import fs
import json
import random
import datetime
import path

function main(): int
    random.seed(42)
    local n: int = random.int(1, 100)
    print(n)
    local ts: int = datetime.now()
    local s: string = datetime.format(ts, "%Y-%m-%d")
    print(s)
    fs.write("test_out.txt", "hello from slua\n")
    local data: string = fs.read_all("test_out.txt")
    print(data)
    local j: string = json.encode_str("hello world")
    print(j)
    local p: string = path.basename("C:/foo/bar/baz.slua")
    print(p)
    return 0
end
