--!!type:strict
--!!mem:auto

import io

function main():int64
    print("string print working")
    io.print_color("=== S Lua IO Test =================", "cyan")
    io.print_color("Enter your name:", "yellow")
    local name:string = io.read_line()
    io.print_color("Hello, ", "green")
    print(name)
    io.reset_color()
    return 0
end
